<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>GiftHub - Simulador de Tiro Parabólico</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:#121212;
    color:white;
    font-family:Arial, Helvetica, sans-serif;
    overflow:hidden;
}

.container{
    display:flex;
    height:100vh;
}

.panel{
    width:320px;
    background:#1f1f1f;
    padding:20px;
    overflow-y:auto;
    border-right:3px solid #333;
}

.panel h1{
    margin-bottom:20px;
    color:#00d4ff;
}

.control{
    margin-bottom:18px;
}

.control label{
    display:block;
    margin-bottom:8px;
}

.control input{
    width:100%;
    padding:10px;
    border:none;
    border-radius:8px;
    font-size:16px;
}

button{
    width:100%;
    padding:14px;
    border:none;
    border-radius:10px;
    background:#00aaff;
    color:white;
    font-size:18px;
    cursor:pointer;
    transition:0.3s;
}

button:hover{
    background:#0088cc;
}

.stats{
    margin-top:20px;
    background:#2a2a2a;
    padding:15px;
    border-radius:10px;
    line-height:1.8;
}

canvas{
    flex:1;
    background:linear-gradient(#6ec6ff,#dff6ff);
}

</style>
</head>

<body>

<div class="container">

    <div class="panel">

        <h1>🎯 Simulador</h1>

        <div class="control">
            <label>Velocidad Inicial (m/s)</label>
            <input type="number" id="velocidad" value="50" min="0" max="100">
        </div>

        <div class="control">
            <label>Ángulo (grados)</label>
            <input type="number" id="angulo" value="45" min="0" max="90">
        </div>

        <div class="control">
            <label>Gravedad</label>
            <input type="number" id="gravedad" value="9.8" min="0.1" max="20" step="0.1">
        </div>

        <div class="control">
            <label>Altura Inicial</label>
            <input type="number" id="altura" value="0" min="0" max="100">
        </div>

        <button onclick="lanzar()">🚀 Lanzar</button>

        <div class="stats">
            <div>📏 Distancia: <span id="distancia">0</span> m</div>
            <div>⬆️ Altura Máxima: <span id="alturaMax">0</span> m</div>
            <div>⏱ Tiempo de Vuelo: <span id="tiempo">0</span> s</div>
        </div>

    </div>

    <canvas id="gameCanvas"></canvas>

</div>

<script>

const canvas = document.getElementById("gameCanvas");
const ctx = canvas.getContext("2d");

function resizeCanvas(){
    canvas.width = window.innerWidth - 320;
    canvas.height = window.innerHeight;
}

resizeCanvas();
window.addEventListener("resize", resizeCanvas);

let proyectil = null;
let trayectoria = [];

function dibujarEscenario(){

    // cielo
    ctx.fillStyle = "#87CEEB";
    ctx.fillRect(0,0,canvas.width,canvas.height);

    // suelo
    ctx.fillStyle = "#2e8b57";
    ctx.fillRect(0,canvas.height - 80,canvas.width,80);

    // líneas guía
    ctx.strokeStyle = "rgba(255,255,255,0.2)";

    for(let i=0;i<canvas.width;i+=50){
        ctx.beginPath();
        ctx.moveTo(i,0);
        ctx.lineTo(i,canvas.height);
        ctx.stroke();
    }

    for(let j=0;j<canvas.height;j+=50){
        ctx.beginPath();
        ctx.moveTo(0,j);
        ctx.lineTo(canvas.width,j);
        ctx.stroke();
    }
}

function dibujarTrayectoria(){

    if(trayectoria.length < 2) return;

    ctx.beginPath();
    ctx.strokeStyle = "yellow";
    ctx.lineWidth = 3;

    for(let i=0;i<trayectoria.length;i++){

        const p = trayectoria[i];

        if(i === 0){
            ctx.moveTo(p.x,p.y);
        }else{
            ctx.lineTo(p.x,p.y);
        }
    }

    ctx.stroke();
}

function dibujarProyectil(){

    if(!proyectil) return;

    ctx.beginPath();
    ctx.fillStyle = "red";
    ctx.arc(proyectil.x, proyectil.y, 12, 0, Math.PI * 2);
    ctx.fill();
}

function actualizar(){

    ctx.clearRect(0,0,canvas.width,canvas.height);

    dibujarEscenario();
    dibujarTrayectoria();
    dibujarProyectil();

    if(proyectil){

        proyectil.t += 0.03;

        const t = proyectil.t;

        const x = proyectil.vx * t;
        const y = proyectil.h + (proyectil.vy * t) - (0.5 * proyectil.g * t * t);

        proyectil.x = 50 + x * 5;
        proyectil.y = (canvas.height - 80) - (y * 5);

        trayectoria.push({
            x:proyectil.x,
            y:proyectil.y
        });

        if(proyectil.y >= canvas.height - 80){

            proyectil = null;
        }
    }

    requestAnimationFrame(actualizar);
}

actualizar();

function lanzar(){

    trayectoria = [];
    proyectil = null;

    const velocidad = parseFloat(document.getElementById("velocidad").value) || 50;
    const anguloGrados = parseFloat(document.getElementById("angulo").value) || 45;
    const gravedad = parseFloat(document.getElementById("gravedad").value) || 9.8;
    const altura = parseFloat(document.getElementById("altura").value) || 0;

    if(velocidad <= 0 || anguloGrados < 0 || anguloGrados > 90 || gravedad <= 0){
        alert("Por favor, ingresa valores válidos");
        return;
    }

    const rad = (anguloGrados * Math.PI) / 180;
    const vx = velocidad * Math.cos(rad);
    const vy = velocidad * Math.sin(rad);

    const tiempoVuelo =
        (vy + Math.sqrt((vy * vy) + (2 * gravedad * altura)))
        / gravedad;

    const distancia = vx * tiempoVuelo;

    const alturaMax =
        altura + ((vy * vy) / (2 * gravedad));

    document.getElementById("distancia").innerText =
        distancia.toFixed(2);

    document.getElementById("alturaMax").innerText =
        alturaMax.toFixed(2);

    document.getElementById("tiempo").innerText =
        tiempoVuelo.toFixed(2);

    proyectil = {
        x:50,
        y:canvas.height - 80,
        vx:vx,
        vy:vy,
        g:gravedad,
        h:altura * 5,
        t:0
    };
}

</script>

</body>
</html>
